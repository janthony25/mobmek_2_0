# Copy to .env (gitignored) and fill in real values before deploying anywhere
# beyond a throwaway local machine. docker compose reads .env automatically.

# --- Database ---
POSTGRES_PASSWORD=postgres

# --- Bootstrap admin account (see docs/auth-module-design.md) ---
# Created once on a fresh database if no Admin account exists yet.
BOOTSTRAP_ADMIN_EMAIL=justforvalo25@gmail.com
BOOTSTRAP_ADMIN_PASSWORD=DevAdmin!2026

# --- Runtime environment ---
# Development auto-applies EF migrations on startup and exposes Swagger — do NOT
# use it in production. Set this to "Production" for a real deployment and run
# migrations as a deliberate separate step (see mobmek_api/CLAUDE.md).
ASPNETCORE_ENVIRONMENT=Development
